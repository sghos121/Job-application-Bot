{
  "manifest_version": 3,
  "name": "Soham's Job Autofiller",
  "version": "1.0",
  "description": "Autofills job applications for Soham Ghosh",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}